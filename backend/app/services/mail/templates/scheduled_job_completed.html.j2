{% extends "_base.html.j2" %}
{% block content %}
<h1 class="m-title force-light" style="margin:0 0 12px;font-size:26px;line-height:1.2;letter-spacing:-0.01em;color:#111827;font-weight:700;">
  Scheduled job completed
</h1>

<p class="m-body force-light-muted" style="margin:0 0 24px;font-size:15px;line-height:1.6;color:#4b5563;">
  The scheduled job "<strong style="color:#111827;font-weight:600;">{{ job_name }}</strong>" finished its run at {{ completed_at_display }}. Open the run history to review the outcome.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
  <tr>
    <td align="center" bgcolor="#2D1B69" style="border-radius:10px;background:#2D1B69;">
      <a href="{{ job_url }}"
         style="display:inline-block;padding:13px 30px;font-size:14px;font-weight:600;letter-spacing:0.005em;color:#ffffff;text-decoration:none;border-radius:10px;">
        Open run history
      </a>
    </td>
  </tr>
</table>

<p style="margin:0;font-size:13px;color:#6b7280;line-height:1.5;">
  Job: <strong style="color:#374151;font-weight:600;">{{ job_name }}</strong> · Run: <span style="color:#374151;">{{ run_id }}</span> · Completed at: {{ completed_at_display }}
</p>
{% endblock %}
